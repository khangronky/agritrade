{
  "name": "agritrade",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "clean": "rm bun.lock && bunx npkill --delete-all -y",
    "dev": "bun --bun next dev --turbopack",
    "devx": "bun sb:start && bun dev",
    "build": "bun --bun next build --turbopack",
    "start": "bun --bun next start",
    "type-check": "tsc --build",
    "format": "biome format",
    "format:fix": "biome format --write",
    "lint": "biome lint",
    "lint:fix": "biome lint --write",
    "format-and-lint": "biome check",
    "format-and-lint:fix": "biome check --write",
    "sbr:link": "bun supabase link",
    "sbr:reset": "bun supabase db reset --linked",
    "sbr:diff": "bun supabase db diff -f new_migration --linked",
    "sbr:typegen": "bun supabase gen types typescript --linked --schema public > ./src/types/supabase.ts && biome format --write ./src/types/supabase.ts",
    "sbr:up": "bun supabase migration up --linked",
    "sbr:sync": "bun supabase db push --linked && bun supabase db pull --linked",
    "sbr:pull": "bun supabase db pull --linked",
    "sbr:push": "bun supabase db push --linked",
    "sb:status": "bun supabase status",
    "sb:start": "bun supabase start",
    "sb:stop": "bun supabase stop",
    "sb:new": "bun supabase migration new new_migration",
    "sb:up": "bun supabase migration up",
    "sb:reset": "bun supabase db reset",
    "sb:diff": "bun supabase db diff -f new_migration",
    "sb:typegen": "bun supabase gen types typescript --local --schema public > ./src/types/supabase.ts && biome format --write ./src/types/supabase.ts"
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.53",
    "@ai-sdk/react": "^3.0.143",
    "@hookform/resolvers": "^5.2.2",
    "@octokit/webhooks": "^14.2.0",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.100.1",
    "@tabler/icons-react": "^3.41.0",
    "@tanstack/react-query": "^5.95.2",
    "@tanstack/react-table": "^8.21.3",
    "ai": "^6.0.141",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.562.0",
    "next": "16.2.1",
    "next-themes": "^0.4.6",
    "octokit": "^5.0.5",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-day-picker": "^9.14.0",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.72.0",
    "react-resizable-panels": "^3.0.6",
    "recharts": "^2.15.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "vaul": "^1.1.2",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.9",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^25.5.0",
    "@types/animejs": "^3.1.13",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "supabase": "^2.84.4",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.2"
  },
  "packageManager": "bun@1.3.11"
}
